---
import { ui } from '../i18n/ui';

const lang  = Astro.url.pathname.startsWith('/en') ? 'en' : 'es';
const t     = ui[lang];
const base  = lang === 'en' ? '/en' : '';

const navItems = [
  { href: `${base}/#about`,          label: t.nav.about      },
  { href: `${base}/#stack`,          label: t.nav.stack      },
  { href: `${base}/#experience`,     label: t.nav.experience },
  { href: `${base}/#projects`,       label: t.nav.projects   },
  { href: `${base}/#certifications`, label: t.nav.certs      },
  { href: '/blog',                   label: t.nav.blog       },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-paper border-b-2 border-ink">
  <nav class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">

    <!-- Logo / Monogram -->
    <a
      href={lang === 'en' ? '/en/' : '/'}
      class="font-mono text-sm font-medium tracking-tight text-ink hover:text-accent transition-colors duration-150"
      aria-label="Marco Limache — Home"
    >
      ML_
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex gap-8 list-none m-0 p-0">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="font-mono text-xs font-medium uppercase tracking-widest text-muted hover:text-ink transition-colors duration-150"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: lang toggle + mobile menu -->
    <div class="flex items-center gap-4">

      <!-- Language toggle -->
      <div class="flex items-center gap-1 font-mono text-xs uppercase tracking-widest" aria-label="Language">
        <a
          href="/"
          class={lang === 'es'
            ? 'text-ink font-medium'
            : 'text-muted hover:text-ink transition-colors duration-150'}
        >
          ES
        </a>
        <span class="text-border select-none">·</span>
        <a
          href="/en/"
          class={lang === 'en'
            ? 'text-ink font-medium'
            : 'text-muted hover:text-ink transition-colors duration-150'}
        >
          EN
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="md:hidden font-mono text-xs uppercase tracking-widest"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        Menu
      </button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t-2 border-ink bg-paper"
  >
    <ul class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-4 list-none m-0 p-0">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="font-mono text-sm font-medium uppercase tracking-widest text-muted hover:text-ink transition-colors duration-150 block py-1"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.textContent = isOpen ? 'Menu' : 'Close';
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      if (toggle) toggle.textContent = 'Menu';
    });
  });
</script>
