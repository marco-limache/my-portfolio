---
const navItems = [
  { href: '/#about',      label: 'About'      },
  { href: '/#stack',      label: 'Stack'      },
  { href: '/#experience', label: 'Experience' },
  { href: '/#projects',       label: 'Projects' },
  { href: '/#certifications', label: 'Certs'    },
  { href: '/blog',            label: 'Blog'     },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-paper border-b-2 border-ink">
  <nav class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">

    <!-- Logo / Monogram -->
    <a
      href="/"
      class="font-mono text-sm font-medium tracking-tight text-ink hover:text-accent transition-colors duration-150"
      aria-label="Marco Limache — Home"
    >
      ML_
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex gap-8 list-none m-0 p-0">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="font-mono text-xs font-medium uppercase tracking-widest text-muted hover:text-ink transition-colors duration-150"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden font-mono text-xs uppercase tracking-widest"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      Menu
    </button>
  </nav>

  <!-- Mobile nav -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t-2 border-ink bg-paper"
  >
    <ul class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-4 list-none m-0 p-0">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="font-mono text-sm font-medium uppercase tracking-widest text-muted hover:text-ink transition-colors duration-150 block py-1"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.textContent = isOpen ? 'Menu' : 'Close';
  });

  // Close on nav link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      if (toggle) toggle.textContent = 'Menu';
    });
  });
</script>
