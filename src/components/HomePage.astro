---
import { getCollection } from "astro:content";
import { ui, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateLocale = lang === "es" ? "es-PE" : "en-US";
const formatDate = (d: Date) =>
  d.toLocaleDateString(dateLocale, {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });
---

<!-- ═══════════════════════════════════════════════════════════
     01 · HERO
═══════════════════════════════════════════════════════════ -->
<section
  class="min-h-[calc(100vh-3.5rem)] flex flex-col justify-between border-b-2 border-ink"
>
  <div
    class="max-w-6xl mx-auto px-6 w-full flex-1 flex flex-col justify-center py-20 md:py-28"
  >
    <span class="section-label mb-10 block">{t.hero.sectionLabel}</span>

    <h1
      class="text-6xl md:text-8xl xl:text-9xl font-bold leading-none tracking-tight mb-10"
    >
      {t.hero.line1}<br />
      {t.hero.line2}<br />
      <span class="text-accent">{t.hero.line3}</span>
    </h1>

    <div class="flex flex-wrap gap-3 mb-16">
      {
        t.hero.roles.map((role) => (
          <span class="border-2 border-ink px-4 py-1.5 font-mono text-xs uppercase tracking-widest">
            {role}
          </span>
        ))
      }
    </div>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
      <p class="text-lg text-muted max-w-md leading-relaxed">
        {t.hero.introPre}{" "}
        <a
          href="https://www.trevia.pe"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink font-semibold underline underline-offset-4 hover:text-accent transition-colors"
        >
          Trevia
        </a>.{" "}
        {t.hero.introPost}
      </p>
      <a
        href="#about"
        class="group inline-flex items-center gap-3 font-mono text-sm uppercase tracking-widest self-start md:self-auto"
      >
        {t.hero.cta}
        <span
          class="w-8 h-px bg-ink group-hover:w-14 transition-all duration-300 inline-block"
        ></span>
      </a>
    </div>
  </div>

  <div class="border-t-2 border-ink">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <span class="font-mono text-xs text-muted">marco.limache.dev</span>
      <span class="font-mono text-xs text-muted">
        <span
          class="inline-block w-1.5 h-1.5 rounded-full bg-accent mr-2 animate-pulse"
        ></span>
        {t.hero.status}
      </span>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     02 · ABOUT / MANIFESTO
═══════════════════════════════════════════════════════════ -->
<section id="about" class="py-24 border-b-2 border-ink">
  <div class="max-w-6xl mx-auto px-6">
    <span class="section-label mb-8 block">{t.about.sectionLabel}</span>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
      <!-- The Engineer -->
      <div class="md:border-r-2 border-ink md:pr-16 pb-12 md:pb-0">
        <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-10">
          {t.about.engineerTitle1}<br />{t.about.engineerTitle2}
        </h2>
        <div class="space-y-5 text-lg leading-relaxed text-muted">
          <p>{t.about.engineerP1}</p>
          <p>{t.about.engineerP2}</p>
          <p>
            {t.about.engineerP3Pre}{" "}
            <a
              href="https://www.trevia.pe"
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink font-semibold underline underline-offset-4 hover:text-accent transition-colors"
            >
              Trevia
            </a>{" "}
            {t.about.engineerP3Post}
          </p>
        </div>
      </div>

      <!-- The Person -->
      <div class="md:pl-16 pt-12 md:pt-0">
        <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-10">
          {t.about.personTitle1}<br />{t.about.personTitle2}
        </h2>
        <div class="space-y-5 text-lg leading-relaxed text-muted">
          <p>{t.about.personP1}</p>
          <p>{t.about.personP2}</p>
        </div>
        <blockquote class="mt-10 pl-6 border-l-4 border-accent">
          <p class="text-xl font-bold text-ink leading-snug">
            {t.about.quoteLine1}<br />{t.about.quoteLine2}
          </p>
        </blockquote>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     03 · STACK
═══════════════════════════════════════════════════════════ -->
<section id="stack" class="py-24 border-b-2 border-ink">
  <div class="max-w-6xl mx-auto px-6">
    <span class="section-label mb-8 block">{t.stack.sectionLabel}</span>

    <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-16">
      {t.stack.heading}
    </h2>

    <div
      class="grid grid-cols-2 md:grid-cols-3 border-t-2 border-l-2 border-ink"
    >
      {
        t.stack.groups.map(({ category, items }) => (
          <div class="border-b-2 border-r-2 border-ink p-8 group hover:bg-ink hover:text-paper transition-colors duration-200">
            <p class="font-mono text-xs uppercase tracking-widest text-muted group-hover:text-paper/50 mb-6">
              {category}
            </p>
            <ul class="space-y-2 list-none m-0 p-0">
              {items.map((item) => (
                <li class="text-base md:text-lg font-medium">{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     04 · EXPERIENCE
═══════════════════════════════════════════════════════════ -->
<section id="experience" class="py-24 border-b-2 border-ink">
  <div class="max-w-6xl mx-auto px-6">
    <span class="section-label mb-8 block">{t.experience.sectionLabel}</span>

    <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-16">
      {t.experience.headingLine1}<br />{t.experience.headingLine2}
    </h2>

    <div class="space-y-0">
      {
        t.experience.items.map(({ period, company, role, impact }) => (
          <div class="group border-t-2 border-ink py-8 grid grid-cols-1 md:grid-cols-12 gap-y-2 md:gap-x-4 hover:bg-ink hover:text-paper transition-colors duration-200 px-2 -mx-2">
            <div class="md:col-span-2 font-mono text-xs text-muted group-hover:text-paper/50 flex items-start">
              {period}
            </div>
            <div class="md:col-span-3 font-bold text-sm md:text-base">
              {company}
            </div>
            <div class="md:col-span-3 text-sm md:text-base font-medium">
              {role}
            </div>
            <div class="md:col-span-4 text-sm md:text-base text-muted group-hover:text-paper/60 leading-relaxed">
              {impact}
            </div>
          </div>
        ))
      }
      <div class="border-t-2 border-ink"></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     05 · PROJECTS
═══════════════════════════════════════════════════════════ -->
<section id="projects" class="py-24 border-b-2 border-ink">
  <div class="max-w-6xl mx-auto px-6">
    <span class="section-label mb-8 block">{t.projects.sectionLabel}</span>

    <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-16">
      {t.projects.headingLine1}<br />{t.projects.headingLine2}
    </h2>

    <div class="space-y-0">
      {
        t.projects.items.map(
          ({ number, title, tags, problem, decision, result }) => (
            <div class="border-t-2 border-ink py-12 grid grid-cols-1 md:grid-cols-12 gap-y-8 md:gap-x-12">
              <div class="md:col-span-1">
                <span class="font-mono text-5xl font-bold text-border leading-none">
                  {number}
                </span>
              </div>
              <div class="md:col-span-11">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-8">
                  <h3 class="text-2xl md:text-3xl font-bold leading-tight">
                    {title}
                  </h3>
                  <div class="flex flex-wrap gap-2 flex-shrink-0">
                    {tags.map((tag) => (
                      <span class="font-mono text-xs uppercase tracking-widest border border-border px-3 py-1 text-muted">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 border-t-2 border-l-2 border-ink">
                  {[
                    { label: t.projects.labelProblem, text: problem },
                    { label: t.projects.labelDecision, text: decision },
                    { label: t.projects.labelResult, text: result },
                  ].map(({ label, text }) => (
                    <div class="border-b-2 border-r-2 border-ink p-6">
                      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-4">
                        {label}
                      </p>
                      <p class="text-sm md:text-base text-muted leading-relaxed">
                        {text}
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ),
        )
      }
      <div class="border-t-2 border-ink"></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     06 · BLOG
═══════════════════════════════════════════════════════════ -->
<section id="blog" class="py-24 border-b-2 border-ink">
  <div class="max-w-6xl mx-auto px-6">
    <span class="section-label mb-8 block">{t.blog.sectionLabel}</span>

    <div
      class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16"
    >
      <h2 class="text-4xl md:text-5xl font-bold leading-tight">
        {t.blog.headingLine1}<br />{t.blog.headingLine2}
      </h2>
      <a
        href="/blog"
        class="group inline-flex items-center gap-3 font-mono text-sm uppercase tracking-widest border-2 border-ink px-6 py-3 hover:bg-ink hover:text-paper transition-colors duration-200 self-start md:self-auto whitespace-nowrap"
      >
        {t.blog.allPosts}
      </a>
    </div>

    {
      recentPosts.length > 0 ? (
        <div class="space-y-0">
          {recentPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group block border-t-2 border-ink py-8 grid grid-cols-1 md:grid-cols-12 gap-y-3 md:gap-x-8 hover:bg-ink hover:text-paper transition-colors duration-200 px-2 -mx-2"
            >
              <div class="md:col-span-2 font-mono text-xs text-muted group-hover:text-paper/50">
                {formatDate(post.data.pubDate)}
              </div>
              <div class="md:col-span-8">
                <p class="font-bold text-lg md:text-xl mb-1">
                  {post.data.title}
                </p>
                <p class="text-sm md:text-base text-muted group-hover:text-paper/60 leading-relaxed">
                  {post.data.description}
                </p>
              </div>
              <div class="md:col-span-2 flex flex-wrap gap-1 content-start">
                {post.data.tags?.slice(0, 2).map((tag) => (
                  <span class="font-mono text-xs border border-border group-hover:border-paper/20 px-2 py-0.5 text-muted group-hover:text-paper/50">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))}
          <div class="border-t-2 border-ink" />
        </div>
      ) : (
        <div class="border-t-2 border-ink py-16 text-center">
          <p class="font-mono text-sm text-muted">{t.blog.empty}</p>
        </div>
      )
    }
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     07 · CERTIFICATIONS
═══════════════════════════════════════════════════════════ -->
<section id="certifications" class="py-24 border-b-2 border-ink">
  <div class="max-w-6xl mx-auto px-6">
    <span class="section-label mb-8 block">{t.certs.sectionLabel}</span>

    <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-16">
      {t.certs.headingLine1}<br />{t.certs.headingLine2}
    </h2>

    <div
      class="grid grid-cols-2 md:grid-cols-3 border-t-2 border-l-2 border-ink"
    >
      {
        t.certs.groups.map(({ category, certs }) => (
          <div class="border-b-2 border-r-2 border-ink p-8 group hover:bg-ink hover:text-paper transition-colors duration-200">
            <p class="font-mono text-xs uppercase tracking-widest text-muted group-hover:text-paper/50 mb-6">
              {category}
            </p>
            <ul class="space-y-3 list-none m-0 p-0">
              {certs.map(({ name, issued }) => (
                <li class="flex flex-col gap-0.5">
                  <span class="text-sm md:text-base font-medium leading-snug">
                    {name}
                  </span>
                  <span class="font-mono text-xs text-muted group-hover:text-paper/40">
                    {issued}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     08 · CONTACT
═══════════════════════════════════════════════════════════ -->
<section id="contact" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <span class="section-label mb-8 block">{t.contact.sectionLabel}</span>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-end">
      <div>
        <h2 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
          {t.contact.headingLine1}<br />
          {t.contact.headingLine2}<br />
          <span class="text-accent">{t.contact.headingLine3}</span>
        </h2>
        <p class="text-lg text-muted leading-relaxed max-w-md">
          {t.contact.description}
        </p>
      </div>

      <div class="space-y-4">
        {
          [
            {
              label: "Email",
              href: "mailto:marco.limache@outlook.com",
              value: "marco.limache@outlook.com",
            },
            {
              label: "LinkedIn",
              href: "https://www.linkedin.com/in/mlimache",
              value: "linkedin.com/in/mlimache",
            },
            {
              label: "GitHub",
              href: "https://github.com/marco-limache",
              value: "github.com/marco-limache",
            },
            {
              label: "Trevia",
              href: "https://www.trevia.pe",
              value: "trevia.pe",
            },
          ].map(({ label, href, value }) => (
            <a
              href={href}
              target={href.startsWith("http") ? "_blank" : undefined}
              rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="group flex items-center justify-between border-b-2 border-ink pb-4 hover:border-accent transition-colors duration-200"
            >
              <span class="font-mono text-xs uppercase tracking-widest text-muted group-hover:text-accent transition-colors">
                {label}
              </span>
              <span class="font-medium text-sm md:text-base group-hover:text-accent transition-colors">
                {value}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
