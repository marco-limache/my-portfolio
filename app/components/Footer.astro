---
import { ui } from '../i18n/ui'
const lang = Astro.url.pathname.startsWith('/en') ? 'en' : 'es'
const t = ui[lang]

const year = new Date().getFullYear()
const links = [
  { href: 'mailto:marco.limache@outlook.com', label: 'Email' },
  { href: 'https://www.linkedin.com/in/mlimache', label: 'LinkedIn' },
  { href: 'https://github.com/marco-limache', label: 'GitHub' },
  { href: 'https://www.trevia.pe', label: 'Trevia' },
]
---

<footer class="border-t-2 border-ink bg-ink text-paper">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Identity -->
      <div>
        <p class="font-mono text-xs tracking-widest uppercase text-paper/40 mb-4">Identity</p>
        <p class="font-bold text-xl mb-1">Marco Limache</p>
        <p class="font-mono text-sm text-paper/60">SRE · Cloud Architect · DevOps</p>
      </div>

      <!-- Links -->
      <div>
        <p class="font-mono text-xs tracking-widest uppercase text-paper/40 mb-4">Links</p>
        <ul class="space-y-2 list-none m-0 p-0">
          {
            links.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  target={href.startsWith('http') ? '_blank' : undefined}
                  rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class="font-mono text-sm text-paper/70 hover:text-paper transition-colors duration-150 underline-offset-4 hover:underline"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Status -->
      <div>
        <p class="font-mono text-xs tracking-widest uppercase text-paper/40 mb-4">Status</p>
        <div class="flex items-center gap-2 mb-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block animate-pulse"></span>
          <span class="font-mono text-sm text-paper/70">{t.footer.status}</span>
        </div>
        <p class="font-mono text-sm text-paper/50">{t.footer.location}</p>
      </div>
    </div>

    <!-- Bottom row -->
    <div
      class="border-t border-paper/10 pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-2"
    >
      <span class="font-mono text-xs text-paper/30">
        © {year} Marco Limache. Built with Astro + Cloudflare Pages.
      </span>
      <span class="font-mono text-xs text-paper/30">marco.limache.dev</span>
    </div>
  </div>
</footer>
