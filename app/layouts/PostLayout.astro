---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  description: string
  pubDate: Date
  updatedDate?: Date
  tags?: string[]
  readingTime?: string
}

const { title, description, pubDate, updatedDate, tags = [], readingTime } = Astro.props

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---

<BaseLayout title={`${title} — Marco Limache`} description={description}>
  <article class="border-b-2 border-ink">
    <!-- Post header -->
    <header class="border-b-2 border-ink">
      <div class="max-w-3xl mx-auto px-6 py-16">
        <!-- Back link -->
        <a
          href="/blog"
          class="font-mono text-xs uppercase tracking-widest text-muted hover:text-ink transition-colors duration-150 inline-flex items-center gap-2 mb-12"
        >
          <span class="text-accent">←</span> All posts
        </a>

        <!-- Tags -->
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-8">
              {tags.map((tag) => (
                <span class="font-mono text-xs uppercase tracking-widest border border-border px-3 py-1 text-muted">
                  {tag}
                </span>
              ))}
            </div>
          )
        }

        <!-- Title -->
        <h1 class="text-4xl md:text-6xl font-bold leading-tight tracking-tight mb-8">
          {title}
        </h1>

        <!-- Description -->
        <p class="text-xl text-muted leading-relaxed mb-8">
          {description}
        </p>

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-6 font-mono text-xs text-muted">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {readingTime && <span>{readingTime}</span>}
          {
            updatedDate && (
              <span>
                Updated: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
              </span>
            )
          }
        </div>
      </div>
    </header>

    <!-- Post body -->
    <div class="max-w-3xl mx-auto px-6 py-16">
      <div class="prose-brutal">
        <slot />
      </div>
    </div>

    <!-- Post footer -->
    <div class="max-w-3xl mx-auto px-6 pb-16 border-t-2 border-ink pt-12">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-muted mb-2">Written by</p>
          <p class="font-bold">Marco Limache</p>
          <p class="font-mono text-sm text-muted">SRE · Cloud Architect · DevOps</p>
        </div>
        <a
          href="/blog"
          class="group inline-flex items-center gap-3 font-mono text-sm uppercase tracking-widest border-2 border-ink px-6 py-3 hover:bg-ink hover:text-paper transition-colors duration-200"
        >
          More posts
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
